{
  "name": "sellerpilot-product-image-industrial",
  "version": "0.1.0",
  "description": "Codex skill package for industrial ecommerce product image set planning, generation QA, and review workflows.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ninemouth/sellerpilot-product-image-industrial.git"
  },
  "scripts": {
    "verify": "node scripts/verify-skill.mjs",
    "sync": "node scripts/sync-to-codex-skill.mjs",
    "sync:codex": "node scripts/sync-to-codex-skill.mjs --skill-name sellerpilot-product-image-industrial",
    "build:variant:thinkai": "node scripts/build-thinkai-variant.mjs",
    "sync:thinkai": "npm run build:variant:thinkai && node scripts/sync-to-codex-skill.mjs --source dist/sellerpilot-product-image-industrial-thinkai --skill-name sellerpilot-product-image-industrial-thinkai",
    "paths:codex": "node scripts/codex-path-info.mjs",
    "configure:thinkai": "node scripts/configure-thinkai-runtime.mjs",
    "check:update": "node scripts/check-skill-update.mjs",
    "route:mode": "node scripts/production-mode-router.mjs",
    "plan:efficiency": "node scripts/production-efficiency-plan.mjs",
    "memory:platform": "node scripts/platform-preference-memory.mjs",
    "memory:store-style": "node scripts/store-style-memory.mjs",
    "plan:commerce-research": "node scripts/commerce-design-research-planner.mjs",
    "normalize:source-asset": "node scripts/normalize-source-product-asset.mjs",
    "qa:localized-copy": "node scripts/localized-copy-qa-gate.mjs",
    "qa:text-layout": "node scripts/text-layout-proof-gate.mjs",
    "qa:product-background": "node scripts/product-background-card-consistency-gate.mjs",
    "generate:thinkai": "node scripts/thinkai-image-runtime.mjs",
    "watchdog:runtime": "node scripts/runtime-watchdog.mjs",
    "progress:reconcile": "node scripts/reconcile-generation-progress.mjs",
    "launch:canvas": "node scripts/post-generation-tldraw-launcher.mjs",
    "wait:review": "node scripts/wait-for-review-completion.mjs"
  },
  "optionalDependencies": {
    "playwright": "^1.61.1",
    "sharp": "^0.34.5"
  }
}
