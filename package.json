    "sync:aliases": "node scripts/sync-compatibility-aliases.mjs",
    "sync:thinkai": "node scripts/sync-compatibility-aliases.mjs --only sellerpilot-product-image-industrial-thinkai",
    "paths:codex": "node scripts/codex-path-info.mjs",
    "configure:image-provider": "node scripts/configure-image-provider.mjs",
    "configure:thinkai": "node scripts/configure-image-provider.mjs",
    "check:update": "node scripts/check-skill-update.mjs",
    "route:mode": "node scripts/production-mode-router.mjs",
    "orchestrate:production": "node scripts/production-orchestrator.mjs",
    "plan:efficiency": "node scripts/production-efficiency-plan.mjs",
    "memory:platform": "node scripts/platform-preference-memory.mjs",
    "memory:store-style": "node scripts/store-style-memory.mjs",
    "plan:commerce-research": "node scripts/commerce-design-research-planner.mjs",
    "normalize:source-asset": "node scripts/normalize-source-product-asset.mjs",
